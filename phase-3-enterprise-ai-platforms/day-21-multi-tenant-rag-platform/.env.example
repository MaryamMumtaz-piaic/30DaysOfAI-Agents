# OpenAI API Key for embeddings + chat completion used by the RAG pipeline
OPENAI_API_KEY=your_openai_api_key_here

# JWT secret used to sign per-tenant API tokens
JWT_SECRET=change_me_to_a_long_random_string

# Chroma persistence directory (per-tenant collections live here)
CHROMA_DIR=./chroma_store

# (Optional) Notion integration token for Notion knowledge-base ingestion
# NOTION_API_KEY=your_notion_integration_token_here
