# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Optional: model
OPENAI_MODEL=gpt-4o-mini

# Optional: GitHub token to fetch PR diffs by URL — https://github.com/settings/tokens
# Fine-grained or classic token with "repo" (or public_repo) scope. Leave blank to paste diffs manually.
GITHUB_TOKEN=
